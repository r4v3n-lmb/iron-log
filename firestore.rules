rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return signedIn() && (request.auth.token.admin == true || request.auth.token.role == "admin");
    }
    function isCoachOrAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == "admin" ||
        request.auth.token.role == "coach"
      );
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /ironlog/{docId} {
      allow read, write: if signedIn();
    }

    match /ironlog_profiles/{uid}/health/{docId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isCoachOrAdmin();
      allow create, update, delete: if isOwner(uid) || isAdmin();

      match /{subCollection=**}/{docId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /notifications/{uid}/items/{docId} {
      allow read, update: if isOwner(uid) || isAdmin();
      allow create: if isAdmin() || (signedIn() && request.auth.token.role == "coach");
      allow delete: if isOwner(uid) || isAdmin();
    }

    match /global_workout_templates/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isCoachOrAdmin();
    }

    match /exercise_catalog/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isCoachOrAdmin();
    }

    match /social_posts/{docId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    match /social_following/{uid}/users/{targetUid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /coach_clients/{coachUid}/clients/{clientUid} {
      allow read, write: if isAdmin() || (signedIn() && request.auth.uid == coachUid);
    }

    match /referrals/{code} {
      allow read: if signedIn();
      allow write: if signedIn();
      match /redemptions/{uid} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /analytics_events/{docId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /public_profiles/{uid} {
      allow read: if true;
      allow write: if isOwner(uid) || isAdmin();
    }

    match /webhook_endpoints/{docId} {
      allow read, write: if isAdmin();
    }

    match /webhook_queue/{docId} {
      allow read, write: if isAdmin();
    }

    match /audit_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
