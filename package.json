{
  "name": "ironlog",
  "version": "1.1.46",
  "description": "Workout tracking app with Firebase",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "build:hosting": "node build.js",
    "dev": "node build.js",
    "firebase:serve": "npx firebase emulators:start --only hosting",
    "firebase:deploy": "npm run build:hosting && npx firebase deploy --project ironlog-v1 --only hosting:ironlog-v1"
  },
  "keywords": [
    "fitness",
    "workout"
  ],
  "author": "Revan Lombard",
  "license": "MIT",
  "dependencies": {
    "codex": "^0.2.3",
    "firebase": "^12.11.0"
  },
  "devDependencies": {
    "firebase-tools": "^14.3.1"
  }
}
